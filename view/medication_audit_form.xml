<?xml version="1.0"?>
<form>
    <field name="source_prescription" colspan="4"/>
    <group string="Contexto" colspan="4" col="4" id="group_context">
        <field name="prescription" string="Receta" colspan="2"/>
        <field name="patient" colspan="2"/>
        <field name="medicament" colspan="2"/>
    </group>
    <separator id="sep_audit" colspan="4"/>
    <group string="Estado Auditoria" colspan="4" col="2" id="group_audit_status">
        <label name="audit_state"/>
        <field name="audit_state" string="Estado"/>
        <label name="audit_date"/>
        <field name="audit_date" string="Fecha y Hora Auditoria"/>
        <label name="audit_user"/>
        <field name="audit_user" string="Auditor"/>
    </group>
    <field name="audit_notes" string="Notas" colspan="4"/>
    <label name="package"/>
    <field name="package" readonly="1" colspan="3"/>
</form>
