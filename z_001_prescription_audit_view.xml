<tryton>
    <data noupdate="1">

        <record model="res.group" id="group_prescription_auditor_v3">
            <field name="name">Prescription Auditor v3</field>
        </record>

        <record model="res.group" id="group_audit_overseer">
            <field name="name">Audit Overseer</field>
        </record>

        <!-- ======================================================= -->
        <!-- SEQUENCE: MedicationPurchasePackage                     -->
        <!-- ======================================================= -->

        <record model="ir.sequence.type" id="seq_type_purchase_package">
            <field name="name">Medication Purchase Package</field>
        </record>

        <record model="ir.sequence" id="seq_purchase_package">
            <field name="name">Medication Purchase Package</field>
            <field name="sequence_type" ref="seq_type_purchase_package"/>
            <field name="prefix">PKG-${year}-</field>
            <field name="padding" eval="4"/>
        </record>

    </data>
    <data>

        <!-- ======================================================= -->
        <!-- VIEWS: MedicationAudit                                  -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_medication_audit_list_v3">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="type">tree</field>
            <field name="name">medication_audit_list</field>
        </record>

        <record model="ir.ui.view" id="view_medication_audit_form_v3">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="type">form</field>
            <field name="name">medication_audit_form</field>
        </record>

        <record model="ir.ui.view" id="view_medication_audit_package_list">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="type">tree</field>
            <field name="name">medication_audit_package_list</field>
        </record>

        <!-- ======================================================= -->
        <!-- ACTION WINDOW                                            -->
        <!-- ======================================================= -->

        <record model="ir.action.act_window" id="act_medication_audit_v3">
            <field name="name">Auditoría de Medicamentos</field>
            <field name="res_model">gnuhealth.medication.audit</field>
        </record>

        <record model="ir.action.act_window.view" id="act_medication_audit_view_list_v3">
            <field name="sequence" eval="10"/>
            <field name="view" ref="view_medication_audit_list_v3"/>
            <field name="act_window" ref="act_medication_audit_v3"/>
        </record>

        <record model="ir.action.act_window.view" id="act_medication_audit_view_form_v3">
            <field name="sequence" eval="20"/>
            <field name="view" ref="view_medication_audit_form_v3"/>
            <field name="act_window" ref="act_medication_audit_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- MENU                                                      -->
        <!-- ======================================================= -->

        <menuitem name="Prescription Audit v3"
                  parent="health.gnuhealth_menu"
                  id="menu_prescription_audit_v3"
                  sequence="50"
                  action="act_medication_audit_v3"/>

        <record model="ir.ui.menu-res.group" id="menu_prescription_audit_group_access_v3">
            <field name="menu" ref="menu_prescription_audit_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- MODEL ACCESS                                             -->
        <!-- ======================================================= -->

        <record model="ir.model.access" id="access_medication_audit_auditor_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_select_start_auditor_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit.select.start')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_medication_audit_overseer_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
            <field name="group" ref="group_audit_overseer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_select_start_overseer_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit.select.start')]"/>
            <field name="group" ref="group_audit_overseer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_export_result_auditor_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit.export.result')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <!-- ======================================================= -->
        <!-- VIEWS: MedicationPurchasePackage                        -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_purchase_package_list">
            <field name="model">gnuhealth.medication.purchase.package</field>
            <field name="type">tree</field>
            <field name="name">medication_purchase_package_list</field>
        </record>

        <record model="ir.ui.view" id="view_purchase_package_form">
            <field name="model">gnuhealth.medication.purchase.package</field>
            <field name="type">form</field>
            <field name="name">medication_purchase_package_form</field>
        </record>

        <!-- ======================================================= -->
        <!-- ACTION WINDOW: MedicationPurchasePackage                -->
        <!-- ======================================================= -->

        <record model="ir.action.act_window" id="act_purchase_package">
            <field name="name">Paquetes de Compra</field>
            <field name="res_model">gnuhealth.medication.purchase.package</field>
        </record>

        <record model="ir.action.act_window.view" id="act_purchase_package_view_list">
            <field name="sequence" eval="10"/>
            <field name="view" ref="view_purchase_package_list"/>
            <field name="act_window" ref="act_purchase_package"/>
        </record>

        <record model="ir.action.act_window.view" id="act_purchase_package_view_form">
            <field name="sequence" eval="20"/>
            <field name="view" ref="view_purchase_package_form"/>
            <field name="act_window" ref="act_purchase_package"/>
        </record>

        <!-- ======================================================= -->
        <!-- MENU: Paquetes de Compra                                -->
        <!-- ======================================================= -->

        <menuitem name="Paquetes de Compra"
                  parent="menu_prescription_audit_v3"
                  id="menu_purchase_package"
                  sequence="20"
                  action="act_purchase_package"/>

        <record model="ir.ui.menu-res.group" id="menu_purchase_package_group_access">
            <field name="menu" ref="menu_purchase_package"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- MODEL ACCESS: MedicationPurchasePackage                 -->
        <!-- ======================================================= -->

        <record model="ir.model.access" id="access_purchase_package_auditor">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.purchase.package')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_purchase_package_overseer">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.purchase.package')]"/>
            <field name="group" ref="group_audit_overseer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_create_package_start_auditor">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.purchase.package.create.start')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_create_package_start_overseer">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.purchase.package.create.start')]"/>
            <field name="group" ref="group_audit_overseer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <!-- ======================================================= -->
        <!-- CREATE PACKAGE WIZARD                                   -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_create_package_start">
            <field name="model">gnuhealth.medication.purchase.package.create.start</field>
            <field name="type">form</field>
            <field name="name">create_package_start</field>
        </record>

        <record model="ir.action.wizard" id="act_create_package_wizard">
            <field name="name">Crear Paquete de Compra</field>
            <field name="wiz_name">gnuhealth.medication.purchase.package.create</field>
        </record>

        <record model="ir.action.keyword" id="keyword_create_package">
            <field name="keyword">form_action</field>
            <field name="action" ref="act_create_package_wizard"/>
            <field name="model">gnuhealth.medication.audit,-1</field>
        </record>

        <!-- ======================================================= -->
        <!-- LOAD FROM PRESCRIPTION WIZARD                           -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_select_prescription_start">
            <field name="model">gnuhealth.medication.audit.select.start</field>
            <field name="type">form</field>
            <field name="name">select_prescription_start</field>
        </record>

        <record model="ir.action.wizard" id="act_select_prescription_wizard_v3">
            <field name="name">Cargar desde Receta</field>
            <field name="wiz_name">gnuhealth.medication.audit.select</field>
        </record>

        <record model="ir.action.keyword" id="keyword_load_prescription_v3">
            <field name="keyword">form_action</field>
            <field name="action" ref="act_select_prescription_wizard_v3"/>
            <field name="model">gnuhealth.medication.audit,-1</field>
        </record>

        <menuitem name="Cargar desde Receta"
                  parent="menu_prescription_audit_v3"
                  id="menu_load_prescription_v3"
                  sequence="10"
                  action="act_select_prescription_wizard_v3"/>

        <record model="ir.ui.menu-res.group" id="menu_load_prescription_group_access_v3">
            <field name="menu" ref="menu_load_prescription_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- EXPORT WIZARD                                            -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_audit_export_result">
            <field name="model">gnuhealth.medication.audit.export.result</field>
            <field name="type">form</field>
            <field name="name">medication_audit_export</field>
        </record>

        <record model="ir.action.wizard" id="act_export_audit_wizard_v3">
            <field name="name">Exportar a CSV</field>
            <field name="wiz_name">gnuhealth.medication.audit.export</field>
        </record>

        <record model="ir.action.keyword" id="keyword_export_audit_v3">
            <field name="keyword">form_action</field>
            <field name="action" ref="act_export_audit_wizard_v3"/>
            <field name="model">gnuhealth.medication.audit,-1</field>
        </record>

        <menuitem name="Exportar a CSV"
                  parent="menu_prescription_audit_v3"
                  id="menu_export_audit_csv_v3"
                  sequence="60"
                  action="act_export_audit_wizard_v3"/>

        <record model="ir.ui.menu-res.group" id="menu_export_csv_group_access_v3">
            <field name="menu" ref="menu_export_audit_csv_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- BUTTON RULES                                             -->
        <!-- ======================================================= -->

        <record model="ir.model.button" id="button_approve_line_v3">
            <field name="name">approve_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_approve_line_v3">
            <field name="button" ref="button_approve_line_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <record model="ir.model.button" id="button_reject_line_v3">
            <field name="name">reject_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <!-- No button rule: reject_line visible to all users with write access -->

        <record model="ir.model.button" id="button_reset_line_v3">
            <field name="name">reset_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_reset_line_v3">
            <field name="button" ref="button_reset_line_v3"/>
            <field name="group" ref="group_audit_overseer"/>
        </record>
        <record model="ir.model.button.rule" id="rule_reset_line_auditor_v3">
            <field name="button" ref="button_reset_line_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

    </data>
</tryton>
